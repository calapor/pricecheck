# Postgres (CloudNativePG in-cluster, or Neon). Workers + web + migrations use this.
DATABASE_URL="postgres://pricecheck:pricecheck@localhost:5432/pricecheck"
PG_POOL_MAX=5

# Redis (BullMQ queue + cache)
REDIS_URL="redis://localhost:6379"

# Worker
WORKER_CONCURRENCY=4
BREAKER_THRESHOLD=5
BREAKER_COOLDOWN_MS=60000
METRICS_PORT=9091

# Scheduler
SCHEDULER_BATCH=1000

# Logging
LOG_LEVEL=info
