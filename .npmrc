# Don't re-run `pnpm install` before every `pnpm run` script. The monorepo
# intentionally ignores native build scripts (esbuild, sharp, ...); the pre-run
# verification otherwise exits non-zero on ERR_PNPM_IGNORED_BUILDS in CI.
verify-deps-before-run=false

# Flat, real-directory node_modules (no per-package symlinks into the .pnpm store).
# Kaniko drops symlinked-store contents when snapshotting, which left
# packages/*/node_modules/<dep> dangling (e.g. pino) at runtime. Hoisted is Kaniko-safe
# and applies to both the image build and any in-container pnpm invocation.
node-linker=hoisted
