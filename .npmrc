# Don't re-run `pnpm install` before every `pnpm run` script. The monorepo
# intentionally ignores native build scripts (esbuild, sharp, ...); the pre-run
# verification otherwise exits non-zero on ERR_PNPM_IGNORED_BUILDS in CI.
verify-deps-before-run=false

# Flat, real-directory node_modules (no per-package symlinks into the .pnpm store).
# Applies to both the image build and any in-container pnpm invocation.
node-linker=hoisted

# Copy packages from the global store into node_modules instead of hardlinking.
# pnpm's default ("auto") hardlinks from /pnpm/store; Kaniko's snapshotter
# nondeterministically drops some of those hardlinked store dirs (e.g.
# pino-std-serializers), so deps vanish at runtime (ERR_MODULE_NOT_FOUND). Copying
# makes every file a real, independent file the Kaniko layer captures reliably.
package-import-method=copy

# Extend download timeout for large tarballs (next, sharp) on slow CI links
network-timeout=1800000

# Be more resilient to flaky arm64 tarball fetches (e.g. @next/swc-linux-arm64-gnu)
# over the slow Pi-cluster link: retry more times with a longer backoff window.
fetch-retries=10
fetch-retry-mintimeout=180000
fetch-retry-maxtimeout=180000
